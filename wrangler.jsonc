{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lawler-innovations",
  "compatibility_date": "2026-06-20",
  // Static SPA: serve the built Vite output. Client-side routing (react-router)
  // means unknown paths must fall back to index.html.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
